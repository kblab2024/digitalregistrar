{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lung Cancer Registry Data",
  "description": "Combined JSON Schema for all lung cancer extraction signatures.",
  "type": "object",
  "properties": {
    "LungCancerNonnested": {
      "title": "LungCancerNonnested",
      "type": "object",
      "properties": {
        "procedure": {
          "anyOf": [
            {
              "enum": [
                "wedge_resection",
                "segmentectomy",
                "lobectomy",
                "completion_lobectomy",
                "sleeve_lobectomy",
                "bilobectomy",
                "pneumonectomy",
                "major_airway_resection",
                "others"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify which surgery procedure was used. e.g. polypectomy",
          "title": "Procedure"
        },
        "surgical_technique": {
          "anyOf": [
            {
              "enum": [
                "open",
                "thoracoscopic",
                "robotic",
                "hybrid",
                "others"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify how the surgery was taken. e.g. thoracoscopic",
          "title": "Surgical Technique"
        },
        "sideness": {
          "anyOf": [
            {
              "enum": [
                "right",
                "left",
                "midline"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify which side the tumor is located. e.g. right",
          "title": "Sideness"
        },
        "cancer_primary_site": {
          "anyOf": [
            {
              "enum": [
                "upper_lobe",
                "middle_lobe",
                "lower_lobe",
                "main_bronchus",
                "bronchus_intermedius",
                "bronchus_lobar",
                "others"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify the primary site of cancer. e.g. upper_lobe",
          "title": "Cancer Primary Site"
        },
        "tumor_focality": {
          "anyOf": [
            {
              "enum": [
                "single_focus",
                "separate_in_same_lobe_t3",
                "separate_nodule_in_ipsilateral_t4",
                "separate_nodule_in_contralateral_m1a"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify whether the tumor is single focus or multiple foci; this is important for t and m category",
          "title": "Tumor Focality"
        },
        "histology": {
          "anyOf": [
            {
              "enum": [
                "adenocarcinoma",
                "squamous_cell_carcinoma",
                "adenosquamous_carcinoma",
                "large_cell_carcinoma",
                "large_cell_neuroendocrine_carcinoma",
                "small_cell_carcinoma",
                "carcinoid_tumor",
                "sarcomatoid_carcinoma",
                "pleomorphic_carcinoma",
                "pulmonary_lymphoepithelioma_like_carcinoma",
                "mucoepidermoid_carcinoma",
                "salivary_gland_type_tumor",
                "non_small_cell_carcinoma_not_specified",
                "non_small_cell_carcinoma_with_neuroendocrine_features",
                "other"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify the histological type of the cancer. e.g. adenocarcinoma",
          "title": "Histology"
        },
        "grade": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify the grade of the cancer, well->1, moderate->2, poor->3, undiff->4",
          "title": "Grade"
        },
        "lymphovascular_invasion": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "check whether or not lymphovascular invasion is present",
          "title": "Lymphovascular Invasion"
        },
        "perineural_invasion": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "check whether or not perineural invasion is present",
          "title": "Perineural Invasion"
        },
        "spread_through_air_spaces_stas": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "check whether or not spread through air spaces (STAS) is present",
          "title": "Spread Through Air Spaces Stas"
        },
        "visceral_pleural_invasion": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "check whether or not visceral pleural invasion is present",
          "title": "Visceral Pleural Invasion"
        },
        "direct_invasion_of_adjacent_structures": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "check whether or not direct invasion of adjacent structures is present",
          "title": "Direct Invasion Of Adjacent Structures"
        },
        "distant_metastasis": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "check whether or not distant metastasis is present",
          "title": "Distant Metastasis"
        },
        "treatment_effect": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "check the treatment effect of the cancer. If you see \"No known presurgical therapy\", return None",
          "title": "Treatment Effect"
        }
      }
    },
    "LungCancerStaging": {
      "title": "LungCancerStaging",
      "type": "object",
      "properties": {
        "tnm_descriptor": {
          "anyOf": [
            {
              "enum": [
                "y",
                "r",
                "m"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify the tnm descriptor of the tumor. e.g., \"y\" (post-therapy), \"r\", etc.",
          "title": "Tnm Descriptor"
        },
        "pt_category": {
          "anyOf": [
            {
              "enum": [
                "tx",
                "tis",
                "t1mi",
                "t1a",
                "t1b",
                "t1c",
                "t2a",
                "t2b",
                "t3",
                "t4"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify the pt category of the tumor",
          "title": "Pt Category"
        },
        "pn_category": {
          "anyOf": [
            {
              "enum": [
                "nx",
                "n0",
                "n1",
                "n2",
                "n3"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify the pn category of the tumor",
          "title": "Pn Category"
        },
        "pm_category": {
          "anyOf": [
            {
              "enum": [
                "mx",
                "m0",
                "m1a",
                "m1b",
                "m1c"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify the pm category of the tumor. if you see cM0 or cM1, etc., code as mx, since pathological M category is not available",
          "title": "Pm Category"
        },
        "stage_group": {
          "anyOf": [
            {
              "enum": [
                "0",
                "ia1",
                "ia2",
                "ia3",
                "ib",
                "iia",
                "iib",
                "iiia",
                "iiib",
                "iiic",
                "iva",
                "ivb",
                "ivc"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify the stage group of the tumor",
          "title": "Stage Group"
        },
        "ajcc_version": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify the ajcc version of the pathological staging",
          "title": "Ajcc Version"
        }
      }
    },
    "LungCancerMargins": {
      "title": "LungCancerMargins",
      "type": "object",
      "properties": {
        "margins": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/LungMargin"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "return all of the possible involved margins and its distance from cancer. If not present, just output null for every margin",
          "title": "Margins"
        }
      }
    },
    "LungCancerLN": {
      "title": "LungCancerLN",
      "type": "object",
      "properties": {
        "regional_lymph_node": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/LungLN"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "return all of the involved regional lymph node. If not present, just output null for every lymph node",
          "title": "Regional Lymph Node"
        },
        "extranodal_extension": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "check whether or not extranodal extension is present; if no lymph node metastasis, should be None",
          "title": "Extranodal Extension"
        },
        "maximal_ln_size": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "check the maximal size of node metastatic tumor in mm, rounded to integer; if no lymph node metastasis, should be None",
          "title": "Maximal Ln Size"
        }
      }
    },
    "LungCancerBiomarkers": {
      "title": "LungCancerBiomarkers",
      "type": "object",
      "properties": {
        "biomarkers": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/LungBiomarker"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "return all of the examined biomarkers using immunohistochemistry techniques, like alk, ros1, pd-l1. If not present, just output None for every biomarker",
          "title": "Biomarkers"
        }
      }
    },
    "LungCancerOthernested": {
      "title": "LungCancerOthernested",
      "type": "object",
      "properties": {
        "histological_patterns": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/LungHistologicalPattern"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "if the histology is invasive non-mucinous adenocarcinoma, please identify all of the histological patterns and its percentage. if not, return None",
          "title": "Histological Patterns"
        }
      }
    }
  },
  "$defs": {
    "LungMargin": {
      "properties": {
        "margin_category": {
          "anyOf": [
            {
              "enum": [
                "bronchial",
                "vascular",
                "parenchymal",
                "chest_wall",
                "others"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "acceptable value for surgical margins in lung cancer. If not included in these standard margins, should be classified as others.",
          "title": "Margin Category"
        },
        "margin_involved": {
          "title": "Margin Involved",
          "type": "boolean"
        },
        "distance": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "If margin is involved, return 0. If margin is uninvolved/free, try your best to find the distance at both microscopic and macroscopic(gross) description, and specify the distance from tumor to margin in mm, rounded to integer. If the margin is uninvolved/free and, after your best effort, the distance is still not specified, return null",
          "title": "Distance"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Description"
        }
      },
      "required": [
        "margin_involved",
        "description"
      ],
      "title": "LungMargin",
      "type": "object"
    },
    "LungLN": {
      "properties": {
        "lymph_node_side": {
          "anyOf": [
            {
              "enum": [
                "right",
                "left"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "acceptable value for lymph node side in lung cancer. If not included in these standard sides, should be classified as None.",
          "title": "Lymph Node Side"
        },
        "lymph_node_category": {
          "anyOf": [
            {
              "enum": [
                "peribronchial",
                "1",
                "2",
                "4",
                "5",
                "6",
                "8",
                "9",
                "10",
                "11",
                "12",
                "13",
                "14",
                "3a",
                "3p",
                "7",
                "others"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "acceptable value for lymph node categories (i.e. stations or groups) in lung cancer. If not included in these standard lymph node 'stations'/'groups' should be classified as others.",
          "title": "Lymph Node Category"
        },
        "involved": {
          "title": "Involved",
          "type": "integer"
        },
        "examined": {
          "title": "Examined",
          "type": "integer"
        },
        "station_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "specify the name of the lymph node station/group here.",
          "title": "Station Name"
        }
      },
      "required": [
        "involved",
        "examined"
      ],
      "title": "LungLN",
      "type": "object"
    },
    "LungBiomarker": {
      "properties": {
        "biomarker_category": {
          "anyOf": [
            {
              "enum": [
                "ALK",
                "ROS1",
                "PDL1",
                "others"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "acceptable value for biomarker categories in lung cancer. If not included in these standard categories, should be classified as others.",
          "title": "Biomarker Category"
        },
        "expression": {
          "title": "Expression",
          "type": "boolean"
        },
        "percentage": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "the percentage of tumor cells showing positive expression of the biomarker, rounded to integer. if not specified, return None",
          "title": "Percentage"
        },
        "biomarker_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "specify the name of the biomarker here.",
          "title": "Biomarker Name"
        }
      },
      "required": [
        "expression"
      ],
      "title": "LungBiomarker",
      "type": "object"
    },
    "LungHistologicalPattern": {
      "properties": {
        "pattern_name": {
          "anyOf": [
            {
              "enum": [
                "acinar",
                "lepidic",
                "papillary",
                "solid",
                "micropapillary",
                "others"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "histological pattern of invasive non-mucinous adenocarcinoma",
          "title": "Pattern Name"
        },
        "pattern_percentage": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "percentage of the histological pattern",
          "title": "Pattern Percentage"
        }
      },
      "title": "LungHistologicalPattern",
      "type": "object"
    }
  }
}