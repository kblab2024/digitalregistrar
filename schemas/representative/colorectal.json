{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Colorectal Cancer Registry Data",
  "description": "Combined JSON Schema for all colorectal cancer extraction signatures.",
  "type": "object",
  "properties": {
    "ColonCancerNonnested": {
      "title": "ColonCancerNonnested",
      "type": "object",
      "properties": {
        "procedure": {
          "anyOf": [
            {
              "enum": [
                "right_hemicolectomy",
                "extended_right_hemicolectomy",
                "left_hemicolectomy",
                "low_anterior_resection",
                "anterior_resection",
                "abdominoperineal_resection",
                "total_mesorectal_excision",
                "total_colectomy",
                "subtotal_colectomy",
                "segmental_colectomy",
                "transanal_local_excision",
                "polypectomy",
                "others"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify which surgery procedure was used. e.g. polypectomy",
          "title": "Procedure"
        },
        "surgical_technique": {
          "anyOf": [
            {
              "enum": [
                "open",
                "laparoscopic",
                "robotic",
                "ta_tme",
                "hybrid",
                "others"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify how the surgery was taken. e.g. laparoscopic",
          "title": "Surgical Technique"
        },
        "cancer_primary_site": {
          "anyOf": [
            {
              "enum": [
                "cecum",
                "ascending_colon",
                "hepatic_flexure",
                "transverse_colon",
                "splenic_flexure",
                "descending_colon",
                "sigmoid_colon",
                "rectosigmoid_junction",
                "rectum",
                "appendix"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify the primary site of cancer. e.g. sigmoid colon",
          "title": "Cancer Primary Site"
        },
        "histology": {
          "anyOf": [
            {
              "enum": [
                "adenocarcinoma",
                "mucinous_adenocarcinoma",
                "signet_ring_cell_carcinoma",
                "medullary_carcinoma",
                "micropapillary_adenocarcinoma",
                "serrated_adenocarcinoma",
                "adenosquamous_carcinoma",
                "neuroendocrine_carcinoma",
                "others"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify the histological type of the cancer. e.g. adenocarcinoma, if not in the list, classify as others",
          "title": "Histology"
        },
        "grade": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify the grade of the cancer, well->1, moderate->2, poor->3, undiff-4",
          "title": "Grade"
        },
        "tumor_invasion": {
          "anyOf": [
            {
              "enum": [
                "lamina_propria",
                "submucosa",
                "muscularis_propria",
                "pericolorectal_tissue",
                "visceral_peritoneum_surface",
                "adjacent_organs_structures"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify the part invasioned by tumor, e.g lamina propria",
          "title": "Tumor Invasion"
        },
        "lymphovascular_invasion": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "check whether or not lymphovascular invasion is present",
          "title": "Lymphovascular Invasion"
        },
        "perineural_invasion": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "check whether or not perineural invasion is present",
          "title": "Perineural Invasion"
        },
        "extracellular_mucin": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "check whether or not extracellular mucin is present",
          "title": "Extracellular Mucin"
        },
        "signet_ring": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "check whether or not signet ring cell is present",
          "title": "Signet Ring"
        },
        "tumor_budding": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify the number of tumor budding of the cancer. low->0, moderate->1, high->2",
          "title": "Tumor Budding"
        },
        "type_of_polyp": {
          "anyOf": [
            {
              "enum": [
                "tubular_adenoma",
                "tubulovillous_adenoma",
                "villous_adenoma",
                "sessile_serrated_adenoma",
                "traditional_serrated_adenoma"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify the type of polyp of the tumor",
          "title": "Type Of Polyp"
        },
        "distant_metastasis": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "check whether or not distant metastasis is present",
          "title": "Distant Metastasis"
        },
        "treatment_effect": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "check the treatment effect of the cancer. If you see \"No known presurgical therapy\", return None",
          "title": "Treatment Effect"
        }
      }
    },
    "ColonCancerStaging": {
      "title": "ColonCancerStaging",
      "type": "object",
      "properties": {
        "tnm_descriptor": {
          "anyOf": [
            {
              "enum": [
                "y",
                "r",
                "m"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify the tnm descriptor of the tumor. e.g., \"y\" means post-therapy, \"m\" means multiple primary tumor, \"r\" means recurrent tumor",
          "title": "Tnm Descriptor"
        },
        "pt_category": {
          "anyOf": [
            {
              "enum": [
                "tx",
                "tis",
                "t1",
                "t2",
                "t3",
                "t4a",
                "t4b"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify the pt category of the tumor",
          "title": "Pt Category"
        },
        "pn_category": {
          "anyOf": [
            {
              "enum": [
                "nx",
                "n0",
                "n1a",
                "n1b",
                "n1c",
                "n2a",
                "n2b"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify the pn category of the tumor",
          "title": "Pn Category"
        },
        "pm_category": {
          "anyOf": [
            {
              "enum": [
                "mx",
                "m0",
                "m1a",
                "m1b",
                "m1c"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify the pm category of the tumor. if you see cM0 or cM1, etc., code as mx, since pathological M category is not available",
          "title": "Pm Category"
        },
        "stage_group": {
          "anyOf": [
            {
              "enum": [
                "0",
                "i",
                "iia",
                "iib",
                "iic",
                "iiia",
                "iiib",
                "iiic",
                "iva",
                "ivb",
                "ivc"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify the stage group of the tumor",
          "title": "Stage Group"
        },
        "ajcc_version": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "identify the ajcc version of the pathological staging",
          "title": "Ajcc Version"
        }
      }
    },
    "ColonCancerMargins": {
      "title": "ColonCancerMargins",
      "type": "object",
      "properties": {
        "margins": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/ColonMargin"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "return all of the possible involved margins and its distance from cancer. If not present, just output null for every margin",
          "title": "Margins"
        }
      }
    },
    "ColonCancerLN": {
      "title": "ColonCancerLN",
      "type": "object",
      "properties": {
        "regional_lymph_node": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/ColonLN"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "return all of the involved regional lymph node. If not present, just output null for every lymph node",
          "title": "Regional Lymph Node"
        },
        "extranodal_extension": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "check whether or not extranodal extension is present; if no lymph node metastasis, should be None",
          "title": "Extranodal Extension"
        },
        "maximal_ln_size": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "check the maximal size of node metastatic tumor in mm, rounded to integer; if no lymph node metastasis, should be None",
          "title": "Maximal Ln Size"
        }
      }
    },
    "ColonCancerBiomarkers": {
      "title": "ColonCancerBiomarkers",
      "type": "object",
      "properties": {
        "biomarkers": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/ColonBiomarker"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "return all of the examined immunoreceptors using immunohistochemistry techniques, like mlh1, msh2, etc. If not present, just output null for every biomarker",
          "title": "Biomarkers"
        }
      }
    }
  },
  "$defs": {
    "ColonMargin": {
      "properties": {
        "margin_category": {
          "anyOf": [
            {
              "enum": [
                "proximal",
                "distal",
                "mesenteric_pedicle",
                "radial_or_circumferencial",
                "outmost_of_adhered_tissue",
                "others"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "acceptable value for surgical margins in colon cancer. If not included in these standard margins, should be classified as others.",
          "title": "Margin Category"
        },
        "margin_involved": {
          "title": "Margin Involved",
          "type": "boolean"
        },
        "distance": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "If margin is involved, return 0. If margin is uninvolved/free, try your best to find the distance at both microscopic and macroscopic(gross) description, and specify the distance from tumor to margin in mm, rounded to integer. If the margin is uninvolved/free and, after your best effort, the distance is still not specified, return null",
          "title": "Distance"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Description"
        }
      },
      "required": [
        "margin_involved",
        "description"
      ],
      "title": "ColonMargin",
      "type": "object"
    },
    "ColonLN": {
      "properties": {
        "lymph_node_category": {
          "anyOf": [
            {
              "enum": [
                "regional",
                "mesenteric",
                "others"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "acceptable value for lymph node categories in colon cancer. If not included in these standard lymph node 'station' number, should be classified as others.",
          "title": "Lymph Node Category"
        },
        "involved": {
          "title": "Involved",
          "type": "integer"
        },
        "examined": {
          "title": "Examined",
          "type": "integer"
        },
        "station_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "specify the name of the lymph node group/station here.",
          "title": "Station Name"
        }
      },
      "required": [
        "involved",
        "examined"
      ],
      "title": "ColonLN",
      "type": "object"
    },
    "ColonBiomarker": {
      "properties": {
        "biomarker_category": {
          "anyOf": [
            {
              "enum": [
                "mlh1",
                "msh2",
                "msh6",
                "pms2",
                "her2",
                "others"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "acceptable value for biomarker categories in colon cancer. If not included in these standard categories, should be classified as others.",
          "title": "Biomarker Category"
        },
        "expression": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "specify whether or not the biomarker is expressed here. For Her-2 please refer to the score field, and don't fill in this field.",
          "title": "Expression"
        },
        "percentage": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "the percentage of tumor cells showing positive expression of the biomarker, rounded to integer. if not specified, return null",
          "title": "Percentage"
        },
        "score": {
          "anyOf": [
            {
              "enum": [
                0,
                1,
                2,
                3
              ],
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "specify the Her-2 expression score, negative: score 0 or 1, equivocal: score 2, positive: score 3 of the biomarker here, if applicable.",
          "title": "Score"
        },
        "biomarker_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "specify the name of the biomarker here.",
          "title": "Biomarker Name"
        }
      },
      "title": "ColonBiomarker",
      "type": "object"
    }
  }
}